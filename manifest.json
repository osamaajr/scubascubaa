{
  "manifest_version": 3,
  "name": "ScubaScubaa",
  "version": "1.0.0",
  "description": "Trigger GATO MODE from your webcam with a nose-hold and side-wave gesture.",
  "action": {
    "default_title": "Open ScubaScubaa"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
